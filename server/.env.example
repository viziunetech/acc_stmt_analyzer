# CashScope API — Environment Variables
# Copy this to .env and fill in real values. NEVER commit .env to git.

# ── Razorpay ──────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ── License ───────────────────────────────────────────
LICENSE_SECRET=a_long_random_string_used_to_sign_keys

# ── Email (Resend) ───────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_i5BNMmY2_7U6hSAvLtjwv4xJCniicC7Tr
# Must be a verified sender domain/email in your Resend account
EMAIL_FROM=CashScope <noreply@cashscope.in>

# ── App ───────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:5173
# In production set to: https://cashscope.in (or your Render URL)
